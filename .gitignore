# Python cache
__pycache__/
*.pyc

# Local user data (EVERYONE keeps their own)
json_configuration/conversations.json
json_configuration/model_config.json
json_configuration/corkboard.json
json_configuration/notes.json

# SSL certificates (each user generates their own, or uses HTTP fallback)
cert_store/

# mkcert executable (downloaded automatically)
mkcert.exe

# Virtual environment
venv/
.env

# IDE junk
.vscode/
.idea/
*.swp

# modular gguf junk – ignore all .gguf files anywhere, especially in /models
*.gguf
/models/*.gguf

# ignore personal file
personal.txt

# do not want to commit any uploaded files, they are user-specific and can be large
static/uploads/

# ==========================
# SQLite databases – do NOT commit
# ==========================
sqlite.db          # old name
sqlite_data/       # entire directory
conversations.db   # main conversation DB
conversation.db    # possible variant
conversation.db  # possible variant
